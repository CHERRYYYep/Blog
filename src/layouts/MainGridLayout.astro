---
import BackToTop from "@components/control/BackToTop.astro";
import Footer from "@components/Footer.astro";
import MusicPlayer from "@components/MusicPlayer.svelte";
import Navbar from "@components/Navbar.astro";
import SideBar from "@components/widget/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import TOC from "../components/widget/TOC.astro";
import { siteConfig } from "../config";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "../constants/constants";
import Layout from "./Layout.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
} = Astro.props;
const hasBannerCredit =
	siteConfig.banner.enable && siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;
const isFullBanner = siteConfig.banner.position === "full";
const bannerHeight = isFullBanner ? 70 : BANNER_HEIGHT;
const mainPanelBannerAnchor = isFullBanner ? 42 : bannerHeight;

const mainPanelTop = siteConfig.banner.enable
	? `calc(${mainPanelBannerAnchor}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)`
	: "5.5rem";
const bannerSources = Array.isArray(siteConfig.banner.src)
	? siteConfig.banner.src
	: [siteConfig.banner.src];
const hasMultipleBannerImages = bannerSources.length > 1;
const bannerControlTop = `${(bannerHeight + BANNER_HEIGHT_EXTEND) / 2}vh`;
const getNeteaseMusicId = (src: string) => {
	const trimmed = src.trim();
	try {
		const musicUrl = new URL(trimmed);
		const isNeteaseMusic =
			musicUrl.hostname === "music.163.com" ||
			musicUrl.hostname.endsWith(".music.163.com");
		if (!isNeteaseMusic) return "";

		const searchId = musicUrl.searchParams.get("id");
		const hashQuery = musicUrl.hash.includes("?")
			? musicUrl.hash.slice(musicUrl.hash.indexOf("?") + 1)
			: "";
		const hashId = hashQuery
			? new URLSearchParams(hashQuery).get("id")
			: null;
		const id = searchId || hashId;
		return id || "";
	} catch {
		return "";
	}
};
const resolveMusicSource = (src: string) => {
	const trimmed = src.trim();
	const neteaseId = getNeteaseMusicId(trimmed);
	if (neteaseId) {
		return `https://music.163.com/song/media/outer/url?id=${neteaseId}.mp3`;
	}
	return trimmed;
};
const normalizeMusicTrack = (
	track:
		| string
		| {
				title?: string;
				artist?: string;
				cover?: string;
				src: string;
		  },
	index: number,
) => {
	if (typeof track === "string") {
		return {
			title: `Track ${index + 1}`,
			src: resolveMusicSource(track),
			neteaseId: getNeteaseMusicId(track),
		};
	}
	return {
		title: track.title || `Track ${index + 1}`,
		artist: track.artist,
		cover: track.cover,
		src: resolveMusicSource(track.src),
		neteaseId: getNeteaseMusicId(track.src),
	};
};
const musicSources = siteConfig.music.src
	? Array.isArray(siteConfig.music.src)
		? siteConfig.music.src
		: [siteConfig.music.src]
	: [];
const musicTracks = [...musicSources, ...(siteConfig.music.tracks || [])]
	.filter((track) => (typeof track === "string" ? track.trim() : track.src.trim()))
	.map(normalizeMusicTrack);
	---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

	<!-- Navbar -->
	<slot slot="head" name="head"></slot>
	{siteConfig.music.enable && musicTracks.length > 0 && (
	    <MusicPlayer
	            client:load
	            tracks={musicTracks}
	            autoplay={siteConfig.music.autoplay}
	            initialVolume={siteConfig.music.volume}
	    />
	)}
	<div id="top-row" class="z-50 pointer-events-none relative transition-all duration-700 max-w-[var(--page-width)] px-0 md:px-4 mx-auto" class:list={[""]}>
    <div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all">
        <Navbar></Navbar>
    </div>
</div>

<!-- Banner -->
{siteConfig.banner.enable && <div id="banner-wrapper" class={`absolute z-10 w-full transition duration-700 overflow-hidden`} style={`top: -${BANNER_HEIGHT_EXTEND}vh`}>
	    <div id="banner" class="relative h-full transition duration-700 opacity-0 scale-105">
	        {bannerSources.map((src, index) => (
	            <ImageWrapper
	                    alt="Banner image of the blog"
	                    class:list={[
	                        "banner-slide object-cover h-full transition-opacity duration-700 absolute inset-0",
	                        {"opacity-100 z-10": index === 0, "opacity-0 z-0 pointer-events-none": index !== 0},
	                    ]}
	                    src={src}
	                    position={siteConfig.banner.position}
	            >
	            </ImageWrapper>
	        ))}
	    </div>
	    {hasMultipleBannerImages && <div id="banner-controls" class="pointer-events-none absolute left-0 right-0 z-40" style={`top: ${bannerControlTop}`}>
	        <button type="button" id="banner-prev" aria-label="Previous banner image" class="pointer-events-auto absolute left-4 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-lg bg-black/45 text-white transition hover:bg-black/60 active:scale-90">
	            <Icon name="material-symbols:chevron-left-rounded" class="text-[1.5rem]" />
	        </button>
	        <button type="button" id="banner-next" aria-label="Next banner image" class="pointer-events-auto absolute right-4 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-lg bg-black/45 text-white transition hover:bg-black/60 active:scale-90">
	            <Icon name="material-symbols:chevron-right-rounded" class="text-[1.5rem]" />
	        </button>
	    </div>}
	</div>}

<!-- Main content -->
<div class="absolute w-full z-30 pointer-events-none" style={`top: ${mainPanelTop}`}>
    <!-- The pointer-events-none here prevent blocking the click event of the TOC -->
    <div class="relative max-w-[var(--page-width)] mx-auto pointer-events-auto">
        <div id="main-grid" class="transition duration-700 w-full left-0 right-0 grid grid-cols-[17.5rem_auto] grid-rows-[auto_1fr_auto] lg:grid-rows-[auto]
    mx-auto gap-4 px-0 md:px-4"
        >
            <!-- Banner image credit -->
            {hasBannerCredit && <a href={siteConfig.banner.credit.url} id="banner-credit" target="_blank" rel="noopener" aria-label="Visit image source"
                                   class:list={["group onload-animation transition-all absolute flex justify-center items-center rounded-full " +
                                   "px-3 right-4 -top-[3.25rem] bg-black/60 hover:bg-black/70 h-9", {"hover:pr-9 active:bg-black/80": hasBannerLink}]}
            >
                <Icon class="text-white/75 text-[1.25rem] mr-1" name="material-symbols:copyright-outline-rounded" ></Icon>
                <div class="text-white/75 text-xs">{siteConfig.banner.credit.text}</div>
                <Icon class:list={["transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
                    {"group-hover:opacity-100": hasBannerLink}]}
                      name="fa6-solid:arrow-up-right-from-square">
                </Icon>
            </a>}


            <SideBar class="mb-4 row-start-2 row-end-3 col-span-2 lg:row-start-1 lg:row-end-2 lg:col-span-1 lg:max-w-[17.5rem] onload-animation" headings={headings}></SideBar>

            <main id="swup-container" class="transition-swup-fade col-span-2 lg:col-span-1 overflow-hidden">
                <div id="content-wrapper" class="onload-animation">
                    <!-- the overflow-hidden here prevent long text break the layout-->
                    <!-- make id different from windows.swup global property -->
                    <slot></slot>
                    <div class="footer col-span-2 onload-animation hidden lg:block">
                        <Footer></Footer>
                    </div>
                </div>
            </main>

            <div class="footer col-span-2 onload-animation block lg:hidden">
                <Footer></Footer>
            </div>
        </div>

        <BackToTop></BackToTop>
    </div>
</div>

<!-- The things that should be under the banner, only the TOC for now -->
<div class="absolute w-full z-0 hidden 2xl:block">
    <div class="relative max-w-[var(--page-width)] mx-auto">
        <!-- TOC component -->
        {siteConfig.toc.enable && <div id="toc-wrapper" class:list={["hidden lg:block transition absolute top-0 -right-[var(--toc-width)] w-[var(--toc-width)] items-center",
            {"toc-hide": siteConfig.banner.enable}]}
        >
            <div id="toc-inner-wrapper" class="fixed top-14 w-[var(--toc-width)] h-[calc(100vh_-_20rem)] overflow-y-scroll overflow-x-hidden hide-scrollbar">
                <div id="toc" class="w-full h-full transition-swup-fade ">
                    <div class="h-8 w-full"></div>
                    <TOC headings={headings}></TOC>
                    <div class="h-8 w-full"></div>
                </div>
            </div>
        </div>}

        <!-- #toc needs to exist for Swup to work normally -->
        {!siteConfig.toc.enable && <div id="toc"></div>}
    </div>
</div>
</Layout>
